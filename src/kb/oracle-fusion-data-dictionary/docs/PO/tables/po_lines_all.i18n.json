    {
      "id": 1,
      "br": "Visão Geral",
      "en": "Overview",
      "es": "Visión general"
    },
    {
      "id": 2,
      "br": "Armazena as linhas de ordens de compra. Cada linha representa um item ou servico comprado com quantidade, preco unitario, tipo de linha e referencias de catalogo.",
      "en": "Stores purchase order lines. Each line represents an item or service purchased with quantity, unit price, line type, and catalog references.",
      "es": "Almacena las líneas de órdenes de compra. Cada línea representa un artículo o servicio comprado con cantidad, precio unitario, tipo de línea y referencias de catálogo."
    },
    {
      "id": 3,
      "br": "Sufixo _ALL",
      "en": "Suffix _ALL",
      "es": "Sufijo _ALL"
    },
    {
      "id": 4,
      "br": "O sufixo _ALL indica que a tabela armazena dados de todas as business units (multi-org). O filtro por ORG_ID e necessario para consultas por organizacao especifica.",
      "en": "The suffix _ALL indicates that the table stores data for all business units (multi-org). Filtering by ORG_ID is necessary for queries by specific organization.",
      "es": "El sufijo _ALL indica que la tabla almacena datos de todas las unidades de negocio (multi-org). El filtro por ORG_ID es necesario para consultas por organización específica."
    },
