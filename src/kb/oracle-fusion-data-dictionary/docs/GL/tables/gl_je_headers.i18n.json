    {
      "id": 104,
      "br": "O STATUS segue o mesmo padrão do batch: U (não postado), S (selecionado), P (postado), I (erro).",
      "en": null,
      "es": null
    },
    {
      "id": 105,
      "br": "JE_SOURCE identifica a origem: Manual (usuário), Payables (AP), Receivables (AR), Assets (FA), Subledger Accounting (SLA), etc.",
      "en": null,
      "es": null
    },
    {
      "id": 106,
      "br": "JE_CATEGORY classifica o tipo: Adjustment, Accrual, Revaluation, Opening, Closing, etc.",
      "en": null,
      "es": null
    },
    {
      "id": 107,
      "br": "Journals de reversão preenchem REVERSED_JE_HEADER_ID e REVERSAL_FLAG = 'Y'.",
      "en": null,
      "es": null
    },
    {
      "id": 108,
      "br": "REVERSAL_METHOD: C (Change sign) inverte o sinal dos valores; S (Switch) troca débito por crédito.",
      "en": null,
      "es": null
    },
    {
      "id": 109,
      "br": "O CURRENCY_CODE pode ser diferente da moeda funcional do ledger — neste caso, CURRENCY_CONVERSION_RATE indica a taxa aplicada.",
      "en": null,
      "es": null
    },
    {
      "id": 110,
      "br": "Journals com ACCRUAL_REV_FLAG = 'Y' são marcados para reversão automática no período indicado em ACCRUAL_REV_PERIOD_NAME.",
      "en": null,
      "es": null
    },
