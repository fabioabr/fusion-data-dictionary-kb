    {
      "id": 55,
      "br": "Os tipos Spot, Corporate e User são predefinidos pelo Oracle e não devem ser removidos.",
      "en": null,
      "es": null
    },
    {
      "id": 56,
      "br": "O tipo User é especial — permite que o usuário informe a taxa manualmente na transação, sem depender de taxas carregadas na gl_daily_rates.",
      "en": null,
      "es": null
    },
    {
      "id": 57,
      "br": "Tipos customizados (ex: \"BACEN\", \"ECB\") podem ser criados para representar fontes específicas de cotação.",
      "en": null,
      "es": null
    },
    {
      "id": 58,
      "br": "O CONVERSION_TYPE é o código interno (usado em joins), enquanto USER_CONVERSION_TYPE é o nome exibido na interface.",
      "en": null,
      "es": null
    },
    {
      "id": 59,
      "br": "Todos os módulos financeiros (AP, AR, FA, Projects) referenciam esta tabela para conversão de moedas em transações.",
