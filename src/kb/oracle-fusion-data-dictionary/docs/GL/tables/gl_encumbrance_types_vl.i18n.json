    {
      "id": 50,
      "br": "Esta é uma view, não uma tabela física. Dados originam de GL_ENCUMBRANCE_TYPES_B (base) e GL_ENCUMBRANCE_TYPES_TL (traduções).",
      "en": null,
      "es": null
    },
    {
      "id": 51,
      "br": "O filtro de idioma é aplicado automaticamente pela view usando USERENV('LANG').",
      "en": null,
      "es": null
    },
    {
      "id": 52,
      "br": "Tipos de encumbrance comuns incluem: Commitment (compromissos de compra), Obligation (obrigações) e tipos customizados por implementação.",
      "en": null,
      "es": null
    },
    {
      "id": 53,
      "br": "O ENCUMBRANCE_TYPE_ID é referenciado em GL_BALANCES quando ACTUAL_FLAG = 'E'.",
      "en": null,
      "es": null
