  "items": [
    {
      "id": 1,
      "br": "Visão Geral",
      "en": null,
      "es": null
    },
    {
      "id": 2,
      "br": "View que combina a tabela base GL_ENCUMBRANCE_TYPES_B com a tabela de traduções GL_ENCUMBRANCE_TYPES_TL, retornando os tipos de reserva (encumbrance) com nome e descrição traduzidos para o idioma da sessão do usuário. É a view recomendada para consultas de front-end e relatórios que precisam exibir o nome do tipo de reserva no idioma correto.",
      "en": null,
      "es": null
    },
    {
      "id": 3,
      "br": "Sufixo _VL",
      "en": null,
      "es": null
    },
    {
      "id": 4,
      "br": "O sufixo _VL (View Layer) indica uma view que junta a tabela base (_B) com a tabela de traduções (_TL), filtrando pelo idioma da sessão (USERENV('LANG')).",
      "en": null,
      "es": null
    },
    {
      "id": 5,
      "br": "Propósito de Negócio",
      "en": null,
      "es": null
    },
    {
      "id": 6,
      "br": "Esta view é utilizada nos seguintes processos:",
      "en": null,
      "es": null
    },
    {
      "id": 7,
      "br": "Exibição dos tipos de encumbrance disponíveis com nome traduzido.",
      "en": null,
      "es": null
    },
    {
      "id": 8,
      "br": "Apresentação dos nomes de reservas em relatórios multi-idioma.",
      "en": null,
      "es": null
    },
    {
      "id": 9,
      "br": "Resolução do nome do tipo de encumbrance referenciado em `GL_BALANCES`.",
      "en": null,
      "es": null
    },
    {
      "id": 10,
      "br": "População de listas de seleção em interfaces de lançamento e consulta.",
      "en": null,
      "es": null
    },
    {
      "id": 11,
      "br": "Identificação legível dos tipos de reserva em análises contábeis.",
      "en": null,
      "es": null
    },
    {
      "id": 12,
      "br": "Colunas Principais",
      "en": null,
      "es": null
    },
    {
      "id": 13,
      "br": "Confiança",
      "en": null,
      "es": null
    },
    {
      "id": 14,
      "br": "Escala de 0% a 100% — grau de certeza da descrição gerada por IA com base na documentação oficial Oracle (OEDMF/BICC Release 13/25A).",
      "en": null,
      "es": null
    },
    {
      "id": 15,
      "br": "- 🟢 81–100% — Coluna presente na documentação oficial Oracle; nome, tipo e descrição confirmados.",
      "en": null,
      "es": null
    },
    {
      "id": 16,
      "br": "- 🟡 51–80% — Coluna inferida por naming convention ou padrão Oracle; tipo exato pode variar.",
      "en": null,
      "es": null
    },
    {
      "id": 17,
      "br": "- 🔴 0–50% — Existência ou tipo incertos; pode não existir no release atual; validar no ambiente.",
