    {
      "id": 65,
      "br": "GL_LOOKUPS pode ser uma view sobre FND_LOOKUP_VALUES com filtro de aplicação GL — a estrutura de colunas pode variar ligeiramente.",
      "en": null,
      "es": null
    },
    {
      "id": 66,
      "br": "A PK composta é LOOKUP_TYPE + LOOKUP_CODE + LANGUAGE.",
      "en": null,
      "es": null
    },
    {
      "id": 67,
      "br": "Sempre filtrar LANGUAGE = USERENV('LANG') para obter descrições no idioma corrente do usuário.",
      "en": null,
      "es": null
    },
    {
      "id": 68,
      "br": "Lookups com ENABLED_FLAG = 'N' ou com END_DATE_ACTIVE no passado são valores desativados — não aparecem em LOVs.",
      "en": null,
      "es": null
    },
    {
      "id": 69,
      "br": "Lookups do tipo \"seeded\" (pré-definidos pela Oracle) não devem ser alterados — apenas lookups custom podem ser modificados.",
      "en": null,
      "es": null
    },
    {
      "id": 70,
      "br": "Para criar novos lookup types para o GL, usar a UI de Manage Lookups no Oracle Fusion.",
      "en": null,
      "es": null
    },
