    {
      "id": 1,
      "br": "Visão Geral",
      "en": null,
      "es": null
    },
    {
      "id": 2,
      "br": "Armazena os valores de lookup (referência) utilizados pelo módulo General Ledger. É uma view ou tabela que consolida lookup types e seus valores associados, usados para validação e exibição de campos codificados em telas e relatórios do GL. Segue o padrão Oracle de lookups — cada LOOKUP_TYPE agrupa um conjunto de LOOKUP_CODE com significados e descrições traduzidas.",
      "en": null,
      "es": null
    },
    {
      "id": 3,
      "br": "Tabela/View de referência",
      "en": null,
      "es": null
    },
    {
      "id": 4,
      "br": "GL_LOOKUPS pode ser uma view sobre FND_LOOKUP_VALUES filtrada para o módulo GL. Os lookup types definem listas de valores válidos para campos codificados do GL (status, tipos, categorias etc.).",
      "en": null,
      "es": null
    },
    {
      "id": 5,
      "br": "Propósito de Negócio",
      "en": null,
      "es": null
    },
    {
      "id": 6,
      "br": "Esta tabela é utilizada nos seguintes processos:",
      "en": null,
      "es": null
    },
    {
      "id": 7,
      "br": "Garantir que valores inseridos em campos codificados sejam válidos.",
      "en": null,
      "es": null
    },
    {
      "id": 8,
      "br": "Converter códigos internos em descrições amigáveis (ex: 'P' → 'Posted').",
      "en": null,
      "es": null
    },
    {
      "id": 9,
      "br": "Tradução de códigos para nomes descritivos nos reports.",
      "en": null,
      "es": null
    },
    {
      "id": 10,
      "br": "Definição de valores válidos para dropdowns e LOVs nas telas do GL.",
      "en": null,
      "es": null
    },
    {
      "id": 11,
      "br": "Descrições traduzidas por idioma para cada lookup value.",
      "en": null,
      "es": null
