    {
      "id": 1,
      "br": "Visao Geral",
      "en": null,
      "es": null
    },
    {
      "id": 2,
      "br": "Armazena os saldos orçamentários por conta contábil, período e moeda no General Ledger. Cada registro representa o valor orçado para uma combinação de conta (CCID) em um período específico, vinculado a um orçamento e sua versão. É a tabela central para análises de Budget vs Actual e controle orçamentário.",
      "en": null,
      "es": null
    },
    {
      "id": 3,
      "br": "Relação com GL_BALANCES",
      "en": null,
      "es": null
    },
    {
      "id": 4,
      "br": "Os saldos orçamentários também podem ser consultados via [[gl_balances]] com ACTUAL_FLAG = 'B'. Esta tabela dedicada oferece colunas adicionais específicas de orçamento, como versão e organização orçamentária.",
      "en": null,
      "es": null
    },
    {
      "id": 5,
      "br": "Proposito de Negocio",
      "en": null,
      "es": null
    },
    {
      "id": 6,
      "br": "Esta tabela é utilizada nos seguintes processos:",
      "en": null,
      "es": null
    },
    {
      "id": 7,
      "br": "Acompanhamento de valores orçados por conta contábil e período.",
      "en": null,
      "es": null
    },
    {
      "id": 8,
      "br": "Comparação entre valores orçados e realizados para análise de variações.",
      "en": null,
      "es": null
    },
    {
      "id": 9,
      "br": "Base para revisões orçamentárias e projeções.",
      "en": null,
      "es": null
    },
    {
      "id": 10,
      "br": "Geração de relatórios de consumo orçamentário por departamento ou projeto.",
      "en": null,
      "es": null
    },
    {
      "id": 11,
      "br": "Validação de disponibilidade orçamentária antes de autorizar gastos.",
      "en": null,
      "es": null
    },
    {
      "id": 12,
      "br": "Registro histórico de saldos orçamentários por versão e período.",
      "en": null,
      "es": null
    },
