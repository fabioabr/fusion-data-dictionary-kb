    {
      "id": 66,
      "br": "Apenas contas habilitadas para reconciliação (flag na gl_code_combinations) geram registros nesta tabela.",
      "en": null,
      "es": null
    },
    {
      "id": 67,
      "br": "A reconciliação é tipicamente usada para contas de clearing/compensação e contas intercompany.",
      "en": null,
      "es": null
    },
    {
      "id": 68,
      "br": "Os campos JGZZ_* são específicos de localizações regionais (Global Descriptive Flexfield) e podem não estar populados em todas as implementações.",
      "en": null,
      "es": null
    },
    {
      "id": 69,
      "br": "O processo de reconciliação pode ser manual (pelo usuário) ou automático (via regras configuradas no GL).",
      "en": null,
      "es": null
    },
    {
      "id": 70,
      "br": "Esta tabela é essencial para o processo de fechamento contábil — contas com linhas não reconciliadas podem bloquear o fechamento.",
      "en": null,
      "es": null
    },
