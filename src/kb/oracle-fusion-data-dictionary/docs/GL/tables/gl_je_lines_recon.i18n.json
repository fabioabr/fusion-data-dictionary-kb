  "items": [
    {
      "id": 1,
      "br": "Visão Geral",
      "en": null,
      "es": null
    },
    {
      "id": 2,
      "br": "Armazena informações de reconciliação de linhas de lançamentos contábeis no General Ledger. Esta tabela registra o status e os detalhes de reconciliação de cada linha de journal, permitindo identificar quais linhas já foram reconciliadas, por quem e quando. É utilizada pelo recurso de Journal Reconciliation do Oracle Fusion GL.",
      "en": null,
      "es": null
    },
    {
      "id": 3,
      "br": "Tabela auxiliar de reconciliação",
      "en": null,
      "es": null
    },
    {
      "id": 4,
      "br": "Nem todas as linhas de journal possuem registro nesta tabela — apenas aquelas cujas contas estão habilitadas para reconciliação (JGZ_RECONCILIATION_FLAG em [[gl_code_combinations]]).",
      "en": null,
      "es": null
    },
    {
      "id": 5,
      "br": "Propósito de Negócio",
      "en": null,
      "es": null
    },
    {
      "id": 6,
      "br": "Esta tabela é utilizada nos seguintes processos:",
      "en": null,
      "es": null
    },
    {
      "id": 7,
      "br": "Marcação de linhas de journal como reconciliadas.",
      "en": null,
      "es": null
    },
    {
      "id": 8,
      "br": "Rastreamento de quem reconciliou cada lançamento e quando.",
      "en": null,
      "es": null
    },
    {
      "id": 9,
      "br": "Identificação de linhas pendentes de reconciliação no encerramento do período.",
      "en": null,
      "es": null
    },
    {
      "id": 10,
      "br": "Monitoramento de contas de compensação (clearing accounts) que devem ter saldo zero.",
      "en": null,
      "es": null
    },
    {
      "id": 11,
      "br": "Evidência de revisão contábil para fins regulatórios.",
      "en": null,
      "es": null
    },
    {
      "id": 12,
      "br": "Colunas Principais",
      "en": null,
      "es": null
    },
    {
      "id": 13,
      "br": "Confiança",
      "en": null,
      "es": null
    },
    {
      "id": 14,
      "br": "Escala de 0% a 100% — grau de certeza da descrição gerada por IA com base na documentação oficial Oracle (OEDMF/BICC Release 13/25A).",
      "en": null,
      "es": null
    },
    {
      "id": 15,
      "br": "- 🟢 81–100% — Coluna presente na documentação oficial Oracle; nome, tipo e descrição confirmados.",
      "en": null,
      "es": null
    },
    {
      "id": 16,
      "br": "- 🟡 51–80% — Coluna inferida por naming convention ou padrão Oracle; tipo exato pode variar.",
      "en": null,
      "es": null
    },
    {
      "id": 17,
      "br": "- 🔴 0–50% — Existência ou tipo incertos; pode não existir no release atual; validar no ambiente.",
      "en": null,
      "es": null
    },
