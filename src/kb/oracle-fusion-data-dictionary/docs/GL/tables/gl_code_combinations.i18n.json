    {
      "id": 1,
      "br": "Visão Geral",
      "en": null,
      "es": null
    },
    {
      "id": 2,
      "br": "Armazena todas as combinações válidas de segmentos contábeis (CCID — Code Combination ID) do plano de contas. Cada registro representa uma combinação única de segmentos (empresa, conta, centro de custo, projeto, etc.) utilizada em lançamentos contábeis. É a tabela de referência central do GL — praticamente toda tabela financeira do ERP aponta para ela via CODE_COMBINATION_ID.",
      "en": null,
      "es": null
    },
    {
      "id": 3,
      "br": "Tabela referenciada por todo o ERP",
      "en": null,
      "es": null
    },
    {
      "id": 4,
      "br": "GL_CODE_COMBINATIONS é a tabela mais referenciada do Oracle Fusion. Módulos como AP, AR, FA, PO e Cash Management apontam para ela via CODE_COMBINATION_ID em suas distribuições contábeis.",
      "en": null,
      "es": null
    },
    {
      "id": 5,
      "br": "Propósito de Negócio",
      "en": null,
      "es": null
    },
    {
      "id": 6,
      "br": "Esta tabela é utilizada nos seguintes processos:",
      "en": null,
      "es": null
    },
    {
      "id": 7,
      "br": "Armazena todas as combinações válidas de segmentos contábeis.",
      "en": null,
      "es": null
    },
    {
      "id": 8,
      "br": "Todo lançamento no GL referencia um CCID desta tabela.",
      "en": null,
      "es": null
    },
    {
      "id": 9,
      "br": "AP, AR, FA usam CCID para contabilização.",
      "en": null,
