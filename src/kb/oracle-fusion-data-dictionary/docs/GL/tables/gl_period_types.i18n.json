    {
      "id": 58,
      "br": "A maioria das implementações utiliza o tipo Month com NUMBER_PER_FISCAL_YEAR = 12 como padrão.",
      "en": null,
      "es": null
    },
    {
      "id": 59,
      "br": "O campo YEAR_TYPE_IN_NAME indica se o nome do período usa ano calendário (C) ou fiscal (F) — relevante para empresas com exercício fiscal diferente do calendário civil.",
      "en": null,
      "es": null
    },
    {
      "id": 60,
      "br": "Tipos de período customizados podem ser criados para calendários especiais (ex: semanas 4-4-5 para varejo), mas é raro em instituições financeiras.",
      "en": null,
      "es": null
    },
