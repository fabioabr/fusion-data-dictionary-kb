  "items": [
    {
      "id": 1,
      "br": "Visao Geral",
      "en": null,
      "es": null
    },
    {
      "id": 2,
      "br": "Armazena os conjuntos de acesso a dados contábeis (Data Access Sets) do General Ledger. Cada registro define um agrupamento lógico que controla quais ledgers, segmentos de balancete e combinações de contas um usuário ou responsabilidade pode acessar. É o mecanismo central de segurança de dados financeiros no Oracle Fusion GL.",
      "en": null,
      "es": null
    },
    {
      "id": 3,
      "br": "Segurança de dados",
      "en": null,
      "es": null
    },
    {
      "id": 4,
      "br": "Os Data Access Sets substituem o conceito de Security Rules do EBS. Eles controlam o acesso a ledgers e segmentos de forma granular, permitindo que diferentes equipes vejam apenas os dados financeiros relevantes.",
      "en": null,
      "es": null
    },
    {
      "id": 5,
      "br": "Proposito de Negocio",
      "en": null,
      "es": null
    },
    {
      "id": 6,
      "br": "Esta tabela é utilizada nos seguintes processos:",
      "en": null,
      "es": null
    },
    {
      "id": 7,
      "br": "Controla quais ledgers e segmentos contábeis cada usuário pode consultar e lançar.",
      "en": null,
      "es": null
    },
    {
      "id": 8,
      "br": "Permite que diferentes equipes acessem apenas os dados de suas business units ou centros de custo.",
      "en": null,
      "es": null
    },
    {
      "id": 9,
      "br": "Define o escopo de acesso quando a organização possui múltiplos ledgers (primário, secundário, de reporte).",
      "en": null,
      "es": null
    },
    {
      "id": 10,
      "br": "Rastreamento de quais conjuntos de acesso existem e seus parâmetros.",
      "en": null,
      "es": null
    },
    {
      "id": 11,
      "br": "Base para atribuição de acesso a novos usuários via GL_ACCESS_SET_ASSIGNMENTS.",
      "en": null,
      "es": null
    },
    {
      "id": 12,
      "br": "Colunas Principais",
      "en": null,
      "es": null
    },
    {
      "id": 13,
      "br": "Confiança",
      "en": null,
      "es": null
    },
    {
      "id": 14,
      "br": "Escala de 0% a 100% — grau de certeza da descrição gerada por IA com base na documentação oficial Oracle (OEDMF/BICC Release 13/25A).",
      "en": null,
      "es": null
    },
    {
      "id": 15,
      "br": "- 🟢 81–100% — Coluna presente na documentação oficial Oracle; nome, tipo e descrição confirmados.",
      "en": null,
      "es": null
    },
    {
      "id": 16,
      "br": "- 🟡 51–80% — Coluna inferida por naming convention ou padrão Oracle; tipo exato pode variar.",
      "en": null,
      "es": null
    },
    {
      "id": 17,
      "br": "- 🔴 0–50% — Existência ou tipo incertos; pode não existir no release atual; validar no ambiente.",
      "en": null,
      "es": null
    },
