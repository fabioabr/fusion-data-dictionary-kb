    {
      "id": 60,
      "br": "Cada Data Access Set está vinculado a um plano de contas (Chart of Accounts) e um calendário contábil — não é possível misturar estruturas diferentes em um mesmo conjunto.",
      "en": null,
      "es": null
    },
    {
      "id": 61,
      "br": "O DEFAULT_LEDGER_ID define o ledger que será usado como padrão quando o usuário acessar funcionalidades do GL com esse conjunto.",
      "en": null,
      "es": null
    },
    {
      "id": 62,
      "br": "O SECURITY_SEGMENT_CODE determina qual segmento do plano de contas é usado para restringir acesso (ex: segmento de empresa, centro de custo).",
      "en": null,
      "es": null
    },
    {
      "id": 63,
      "br": "Conjuntos criados automaticamente (AUTOMATICALLY_CREATED_FLAG = 'Y') são gerados pelo sistema ao criar um novo ledger — geralmente concedem acesso total ao ledger.",
      "en": null,
      "es": null
    },
    {
      "id": 64,
      "br": "A tabela gl_access_set_ledgers detalha quais ledgers (além do padrão) fazem parte do conjunto.",
      "en": null,
      "es": null
    },
